# ==================== 存储配置 ====================
# 可选值: minio (推荐), local, oss
STORAGE_TYPE=minio

# ==================== MinIO 配置（推荐，免费本地存储）====================
MINIO_ENDPOINT=http://localhost:9005
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-base
MINIO_REGION=us-east-1

# ==================== 本地存储配置 ====================
LOCAL_STORAGE_ROOT=./storage

# ==================== 阿里云 OSS 配置（可选）====================
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=cn-shanghai
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# ==================== LLM 配置 ====================
DASHSCOPE_API_KEY=
LLM_MODEL=qwen-plus
LLM_CLEAN_MODEL=qwen-turbo
LANGSMITH_TRACING=

# ==================== Milvus 向量数据库 ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# ==================== PostgreSQL 业务数据库 ====================
PG_HOST=localhost
PG_PORT=5432
PG_DB=knowledge_db
PG_USER=kbuser
PG_PASSWORD=kbpass

# ==================== Embedding 配置 ====================
# 调用 DashScope 生成向量，需要 DASHSCOPE_API_KEY
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1536
# 每批最多发送的文本数量（DashScope 单次最多 25 条）
EMBEDDING_BATCH_SIZE=20

# ==================== 向量检索配置 ====================
VECTOR_TOP_K=10
VECTOR_SCORE_THRESHOLD=0

# ==================== Rerank 配置（可选）====================
# Rerank 模型名称
RERANK_MODEL=
# Rerank API 服务地址
RERANK_HOST=
# Rerank API 密钥
RERANK_API_KEY=
# Rerank 超时时间（秒）
RERANK_TIMEOUT=15

# ==================== 切片配置 ====================
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==================== PostgreSQL 配置（docker-compose 用）====================
POSTGRES_DB=knowledge_db
POSTGRES_USER=kbuser
POSTGRES_PASSWORD=kbpass

# ==================== API 配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
SSL_VERIFY=false

# ==================== JWT 认证配置 ====================
# JWT 密钥，生产环境务必修改为强密钥
JWT_SECRET_KEY=change-this-secret-key-in-production
# JWT 算法
JWT_ALGORITHM=HS256
# JWT 过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 管理员邀请码，用于注册管理员用户，留空则不允许注册管理员
ADMIN_INVITE_CODE=
# PBKDF2 哈希轮数
PBKDF2_ROUNDS=310000
